<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkApplicationWindow" id="main_window">
    <property name="title">Hyprland Tweaker</property>
    <property name="default-width">600</property>
    <property name="default-height">400</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="halign">center</property>
        <property name="valign">center</property>
        <property name="spacing">20</property>
        
        <child>
          <object class="GtkLabel">
            <property name="label">Обои (swaybg)</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="btn_wallpaper">
            <property name="label">Выбрать и применить</property>
          </object>
        </child>

        <child>
          <object class="GtkSeparator"/>
        </child>

        <child>
          <object class="GtkLabel">
            <property name="label">Цвет фона Kitty</property>
          </object>
        </child>
        <child>
          <object class="GtkColorDialogButton" id="color_btn_kitty_bg">
            <property name="dialog">
              <object class="GtkColorDialog"/>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="btn_apply_kitty">
            <property name="label">Применить цвет Kitty</property>
          </object>
        </child>

      </object>
    </child>
  </object>
</interface>
